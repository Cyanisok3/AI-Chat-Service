# CppAIService Environment Configuration Template
# 复制此文件为 .env 并填入你的配置

# RabbitMQ 配置 (Docker 服务名)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# MySQL 配置 (Docker 服务名)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=chatserver

# 阿里云 DashScope API Key (必填 - 用于聊天、MCP、RAG通信)
DASHSCOPE_API_KEY=your_api_key_here

# 阿里云百炼知识库 ID (RAG功能需要)
KNOWLEDGE_BASE_ID=your_knowledge_base_id_here

# 豆包 API Key (豆包AI功能)
DOUBAO_API_KEY=your_doubao_api_key_here

# 百度语音合成配置 (语音合成功能)
BAIDU_CLIENT_ID=your_baidu_client_id_here
BAIDU_CLIENT_SECRET=your_baidu_client_secret_here

# 服务器配置
HTTP_PORT=80
